    </div>

    <% if (searchTerm) { %>
    <h4 class="ms-4 mt-3">Showing results for: 
        <span style="color: teal;"><%= searchTerm %></span>
    </h4>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

        <% if (allListings.length === 0) { %>
        <div class="col-12">
            <h5 class="text-danger mt-4 ms-4">No listings found for "<%= searchTerm %>"</h5>
        </div>
    <% } else { %>


        <% for(let listing of allListings){ %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%= listing.image.url  %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                        <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b> <br>
                            &#8377; <%= listing.price.toLocaleString("en-IN") %>/night <br>
                            tax = <%= listing.taxRate %>% <br>
                            ServiceFee = &#8377;<%= listing.serviceFee.toLocaleString("en-IN") %> <br>
                            <% 
                                let totalPrice = listing.price + 
                                                (listing.price * listing.taxRate / 100) + 
                                                listing.serviceFee; 
                            %>
                            <b>Total = &#8377;<%= totalPrice.toLocaleString("en-IN") %></b>
                        </p>
                        
                    </div>
                </div>
            </a>
        <% } %>
        <% } %>
    </div>

</body>

