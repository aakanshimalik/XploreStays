<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-3">

            <h3>
                <%= listing.title %>
            </h3>

        </div>
        <div class="card col-6 offset-3 show-card listing-card">
            <img src="<%= listing.image.url || listing.image %>" class="card-img-top show-img" alt="listing_image" />
            <div class="card-body">
                <p class="card-text">
                    <i><b>Owned By: </b>
                        <%= listing.owner ? listing.owner.username : "Unknown" %>
                    </i>
                </p>
                <p class="card-text">
                    &#8377;<%= listing.price !=null ? listing.price.toLocaleString("en-IN") : "N/A" %>
                </p>
                <p class="card-text">
                    <%= listing.taxRate !=null ? listing.taxRate : "N/A" %> %gst
                </p>
                <p class="card-text">
                    &#8377;<%= listing.serviceFee !=null ? listing.serviceFee.toLocaleString("en-IN") : "N/A" %> service
                        Fee
                </p>
                <p class="card-text">
                    <% if (listing.price !=null && listing.taxRate !=null && listing.serviceFee !=null) { let
                        totalPrice=listing.price + (listing.price * listing.taxRate / 100) + listing.serviceFee; %>
                        <b>Total = &#8377;<%= totalPrice.toLocaleString("en-IN") %></b>
                        <% } else { %>
                            <b>Total = N/A</b>
                            <% } %>
                </p>
                <p class="card-text">
                    <%= listing.location %>
                </p>
                <p class="card-text">
                    <%= listing.country %>
                </p>
            </div>
        </div>

        <br>

        <% if(currUser && listing.owner && listing.owner._id && currUser._id &&
            listing.owner._id.toString()===currUser._id.toString()) { %>
            <div class="btns">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                    <button type="submit" class="btn offset-5 " style="background-color: teal; color: white;"
                        onmouseover="this.style.backgroundColor='#006666'"
                        onmouseout="this.style.backgroundColor='teal'">Delete</button>
                </form>
            </div>
            <% } %>

                <div class="col-8 offset-3 mb-3">

                    <% if(currUser) { %>
                        <hr>
                        <h4>Leave a Review</h4>
                        <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate
                            class="needs-validation">

                            <div class="mb-3 mt-3">
                                <label for="rating" class="form-label">
                                    <b>Rating for Quality</b>
                                </label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate-quality" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="rate-quality-1" name="review[rating]" value="1" />
                                    <label for="rate-quality-1" title="Terrible">1 star</label>
                                    <input type="radio" id="rate-quality-2" name="review[rating]" value="2" />
                                    <label for="rate-quality-2" title="Not good">2 stars</label>
                                    <input type="radio" id="rate-quality-3" name="review[rating]" value="3" />
                                    <label for="rate-quality-3" title="Average">3 stars</label>
                                    <input type="radio" id="rate-quality-4" name="review[rating]" value="4" />
                                    <label for="rate-quality-4" title="Very good">4 stars</label>
                                    <input type="radio" id="rate-quality-5" name="review[rating]" value="5" />
                                    <label for="rate-quality-5" title="Amazing">5 stars</label>
                                </fieldset>

                                <br>

                                <label for="ratingTransparency" class="form-label">
                                    <b>Rating for Transparency</b>
                                </label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate-transparency" class="input-no-rate"
                                        name="review[ratingTransparency]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="rate-transparency-1" name="review[ratingTransparency]"
                                        value="1" />
                                    <label for="rate-transparency-1" title="Terrible">1 star</label>
                                    <input type="radio" id="rate-transparency-2" name="review[ratingTransparency]"
                                        value="2" />
                                    <label for="rate-transparency-2" title="Not good">2 stars</label>
                                    <input type="radio" id="rate-transparency-3" name="review[ratingTransparency]"
                                        value="3" />
                                    <label for="rate-transparency-3" title="Average">3 stars</label>
                                    <input type="radio" id="rate-transparency-4" name="review[ratingTransparency]"
                                        value="4" />
                                    <label for="rate-transparency-4" title="Very good">4 stars</label>
                                    <input type="radio" id="rate-transparency-5" name="review[ratingTransparency]"
                                        value="5" />
                                    <label for="rate-transparency-5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-3 mt-3">
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                                    required></textarea>
                                <div class="invalid-feedback"> Please write a comment before submitting your review
                                </div>
                            </div>

                            <button class="btn btn-outline-dark">Submit</button>
                        </form>
                        <hr>
                        <% } %>

                            <% if(listing.reviews.length> 0){ %>
                                <div class="row">
                                    <p><b>All Reviews</b></p>
                                    <% for(review of listing.reviews){ %>
                                        <div class="card col-5 ms-3 mb-3">
                                            <div class="card-body">
                                                <h5 class="card-title">
                                                    <%= review.author ? review.author.username : "Unknown" %>
                                                </h5>

                                                <p><b>Quality:</b></p>
                                                <p class="starability-result card-text"
                                                    data-rating="<%= review.rating %>">
                                                    Quality Rating: <%= review.rating %>
                                                </p>

                                                <p><b>Transparency:</b></p>
                                                <p class="starability-result card-text"
                                                    data-rating="<%= review.ratingTransparency %>">
                                                    Transparency Rating: <%= review.ratingTransparency %>
                                                </p>

                                                <p class="card-text">
                                                    <%= review.comment %>
                                                </p>
                                            </div>
                                            <form class="mb-3 mt-3" method="POST"
                                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                <button class="btn btn-sm"
                                                    style="background-color: teal; color: white;">Delete</button>
                                            </form>
                                        </div>
                                        <% } %>
                                </div>
                                <% } %>
                </div>

                <div>
                    <% if(listing.hasCabService) { %>

                        <div
                            style="border:1px solid #ddd; padding:20px; border-radius:12px; margin-top:25px; background:#f8f9fa;">

                            <h4 style="color:#206563;">
                                <i class="fa-solid fa-car"></i> Private Cab Facility
                            </h4>

                            <p style="margin-top:10px;">
                                This stay offers a private cab for airport pickup, city tours, and local travel.
                            </p>

                            <p style="font-weight:bold;">
                                Price: ₹<%= listing.cabPrice %> per ride
                            </p>

                            <form action="/listings/<%= listing._id %>/cab" method="POST">
                                <button style="background-color:#206563;
                                color:white;
                                padding:10px 20px;
                                border:none;
                                border-radius:6px;
                                cursor:pointer;">
                                    Book Private Cab
                                </button>
                            </form>
                        </div>

                <% } %>

                </div>

                    <div class="col-6 offset-3 mb-3">
                        <h3>Where you'll be</h3>
                        <div class="map border rounded p-3 text-muted"
                            style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <em>Map feature coming soon.</em>
                        </div>
                    </div>
    </div>