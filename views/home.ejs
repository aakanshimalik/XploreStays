<% layout("/layouts/boilerplate") %>

<!-- Hero Section -->
<section class="text-center" style="margin-top: 80px;">
    <img src="/images/xplorestays-banner.jpeg" class="img-fluid w-100" style="height: 550px; object-fit: cover;" alt="XploreStays Banner">
    <h1 class="mt-3 display-4">Welcome to XploreStays</h1>
    <p class="lead">Transparent pricing & trustworthy reviews for your perfect stay</p>
</section>

<!-- Featured Listings -->
<section class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Featured Listings</h2>
        <a href="/listings" 
   class="btn" 
   style="background-color: #206563; color: white; text-decoration: none; padding: 10px 20px; border-radius: 5px; transition: background-color 0.3s ease;"
   onmouseover="this.style.backgroundColor='#fe424d';"
   onmouseout="this.style.backgroundColor='#206563';">
   Explore More
</a>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4">
        <% if(allListings.length === 0){ %>
            <div class="col-12">
                <h5 class="text-danger mt-4">No listings available</h5>
            </div>
        <% } else { %>
            <% for(let listing of allListings){ %>
                <div class="col">
                    <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm rounded-4">
                            <% if(listing.image && listing.image.url){ %>
                                <img src="<%= listing.image.url %>" class="card-img-top rounded-top-4" style="height: 200px; object-fit: cover;" alt="<%= listing.title %>">
                            <% } else { %>
                                <img src="/images/placeholder.jpg" class="card-img-top rounded-top-4" style="height: 200px; object-fit: cover;" alt="Placeholder">
                            <% } %>
                            <div class="card-body">
                                <h6 class="card-title fw-semibold"><%= listing.title %></h6>
                                <p class="mb-1">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
                                <p class="mb-1">tax = <%= listing.taxRate %>%</p>
                                <p class="mb-1">ServiceFee = &#8377;<%= listing.serviceFee.toLocaleString("en-IN") %></p>
                                <% 
                                    let totalPrice = listing.price + (listing.price * listing.taxRate / 100) + listing.serviceFee;
                                %>
                                <p class="fw-bold">Total = &#8377;<%= totalPrice.toLocaleString("en-IN", {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></p>
                            </div>
                        </div>
                    </a>
                </div>
            <% } %>
        <% } %>
    </div>
</section>

<!-- Testimonial / About Project Section -->
<section class="testimonials" style="background:#f9f9f9; padding:50px 20px;">
  <h2 style="text-align:center; color:#206563;">Featured Projects & Highlights</h2>

  <div style="display:flex; flex-wrap:wrap; gap:20px; justify-content:center; margin-top:30px;">

    <!-- Project 1 -->
    <div style="background:white; padding:25px; border-radius:12px; width:320px; box-shadow:0 4px 6px rgba(0,0,0,0.1);">
      <p style="font-style:italic; color:#333;">
        “XploreStays is a full‑stack Airbnb‑style web app built using Node.js, Express, MongoDB & EJS. It focuses on clear pricing breakdowns and a dual rating system for both Quality and Transparency — an important edge in trust‑driven booking experiences.” 
      </p>
      <h4 style="margin-top:12px; color:#206563;">XploreStays</h4>
      <small style="color:#555;">Full‑Stack Web App | MVC Architecture</small>
    </div>

    <!-- Project 2 -->
    <div style="background:white; padding:25px; border-radius:12px; width:320px; box-shadow:0 4px 6px rgba(0,0,0,0.1);">
      <p style="font-style:italic; color:#333;">
        “Implemented transparent pricing logic that breaks down base price + taxes + service fees, so users know exactly what they’re paying. Integrated user authentication, listing management, and search filters for seamless browsing.”
      </p>
      <h4 style="margin-top:12px; color:#206563;">Detailed Pricing & Filters</h4>
      <small style="color:#555;">Interactive Features | User Flow Enhancements</small>
    </div>

    <!-- Project 3 -->
    <div style="background:white; padding:25px; border-radius:12px; width:320px; box-shadow:0 4px 6px rgba(0,0,0,0.1);">
      <p style="font-style:italic; color:#333;">
        “Built a dual rating system allowing guests to share feedback on both the experience and transparency of listings — helping future users make more informed decisions and fostering trust in the platform.”
      </p>
      <h4 style="margin-top:12px; color:#206563;">Dual Rating System</h4>
      <small style="color:#555;">Quality & Transparency | User Reviews</small>
    </div>

  </div>
</section>