<%- layout("/layouts/boilerplate.ejs") %>
<div class="signup-page">
    <div class="row mt-3 offset-1">
        <h1 class="col-6 offset-2" style="color: teal;">Login</h1>
        <div class="col-6 offset-2">
            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input 
                        name="username" 
                        id="username"
                        type="text" 
                        class="form-control" 
                        required
                    />

                </div>


                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input 
                        name="password" 
                        id="password"
                        type="password" 
                        class="form-control" 
                        required
                    />
                </div>
                <!-- <button class="btn btn-success">SignUp</button> -->
                 <button 
                    class="btn" 
                    style="background-color: #fe424d; color: white;"
                    onmouseover="this.style.backgroundColor='#e6735f'"
                    onmouseout="this.style.backgroundColor='coral'"
                >
                    Login
                </button>
                <p class="mt-3 " style="color: teal; font-weight: 500; ">
    Don't have an account? <a href="/signup" style="color: #fe424d; text-decoration: underline;">Signup</a>
</p>
            </form>
        </div>
    </div>
</div>